# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
TRADING212_API_KEY=...          # T212 Settings → API

# ── Authentication ─────────────────────────────────────────────────────────────
#
# The app supports two auth modes that work independently or together:
#
# Mode A — Trusted networks (for Authelia / reverse proxy setups)
#   Requests arriving from these IP ranges bypass Basic Auth entirely.
#   Add the IP of your nginx/Caddy/Traefik proxy, or your internal subnet.
#   This prevents a double-login when Authelia already authenticated the user.
#   Example: 127.0.0.1/32 (loopback), 192.168.1.0/24 (LAN), 172.16.0.0/12 (Docker)
#
TRUSTED_NETWORKS=127.0.0.1/32,::1/128
#
# Mode B — Basic Auth fallback
#   Applied to any request NOT coming from a TRUSTED_NETWORKS address.
#   Useful as a second layer if someone accesses port 8765 directly on your LAN.
#   Without a reverse proxy in front, this is your only protection — set it.
#
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme     # use a strong password

# ── Report security ────────────────────────────────────────────────────────────
# Set to enable encryption. Use a DIFFERENT value from DASHBOARD_PASSWORD —
# a leaked report file should not also reveal your login password.
# Excel files will be password-protected; text reports Fernet-encrypted.
REPORTS_ENCRYPTION_KEY=

# How many days of reports to keep (auto-deleted on each run)
REPORTS_RETENTION_DAYS=365

# ── Optional (defaults shown) ─────────────────────────────────────────────────
EXCEL_PATH=/data/stocks/stocks.xlsx
DB_PATH=/data/db/stocks.db
REPORTS_DIR=/data/reports

SCHEDULE_DAYS=0,2,5             # Mon/Wed/Sat  (0=Mon … 6=Sun)
SCHEDULE_HOUR=7                 # 07:00 UTC

T212_SYNC_ENABLED=true
T212_SYNC_OFFSET_MINS=30
COST_METHOD=AVCO                # FIFO | AVCO

PORT=8765
