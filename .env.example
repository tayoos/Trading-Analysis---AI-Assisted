# ── Required ──────────────────────────────────────────────────────────────────
# No Anthropic API key needed — analysis runs via your Claude subscription.
# Authenticate once on the host with:  claude login
# Then mount ~/.claude into the container (see docker-compose files).

TRADING212_API_KEY=...          # T212 Settings → API → Key ID
TRADING212_API_SECRET=...       # T212 Settings → API → Secret Key

# Enable scope history:transactions on the key (required for Net deposit on dashboard)
# Optional override if that scope is unavailable: NET_DEPOSITS_OVERRIDE=931
# NET_DEPOSITS_OVERRIDE=931

# ── Authentication ─────────────────────────────────────────────────────────────
#
# The app supports two auth modes that work independently or together:
#
# Mode A — Trusted networks (for Authelia / reverse proxy setups)
#   Requests arriving from these IP ranges bypass Basic Auth entirely.
#   Add the IP of your nginx/Caddy/Traefik proxy, or your internal subnet.
#   This prevents a double-login when Authelia already authenticated the user.
#   Example: 127.0.0.1/32 (loopback), 192.168.1.0/24 (LAN), 172.16.0.0/12 (Docker)
#
TRUSTED_NETWORKS=127.0.0.1/32,::1/128
#
# Mode B — Basic Auth fallback
#   Applied to any request NOT coming from a TRUSTED_NETWORKS address.
#   Useful as a second layer if someone accesses port 8765 directly on your LAN.
#   Without a reverse proxy in front, this is your only protection — set it.
#
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme     # use a strong password

# ── Report security ────────────────────────────────────────────────────────────
# Set to enable encryption. Use a DIFFERENT value from DASHBOARD_PASSWORD —
# a leaked report file should not also reveal your login password.
# Excel files will be password-protected; text reports Fernet-encrypted.
REPORTS_ENCRYPTION_KEY=

# How many days of reports to keep (auto-deleted on each run)
REPORTS_RETENTION_DAYS=365

# ── Optional (defaults shown) ─────────────────────────────────────────────────
EXCEL_PATH=/data/stocks/stocks.xlsx
DB_PATH=/data/db/stocks.db
REPORTS_DIR=/data/reports

SCHEDULE_DAYS=0,2,5             # Mon/Wed/Sat  (0=Mon … 6=Sun)
SCHEDULE_HOUR=7                 # 07:00 UTC

T212_SYNC_ENABLED=true
T212_SYNC_OFFSET_MINS=30
COST_METHOD=AVCO                # FIFO | AVCO

PORT=8765

# ── Backup ─────────────────────────────────────────────────────────────────────
#
# The backup destination is always /data/backups inside the container.
# Backups run automatically when that path is a mounted volume pointing to
# your slow/redundant storage (main Unraid array, NFS share, secondary disk).
# If the volume is not mounted, backups are silently skipped — no config needed.
#
# How many days of backups to keep before the oldest are deleted automatically.
BACKUP_RETAIN_DAYS=60

# ── Unraid-specific ────────────────────────────────────────────────────────────
# Path on the Unraid HOST to your fast ZFS pool appdata share.
# Used in docker-compose.unraid.yml to set primary DB/reports volumes.
# Example: /mnt/cache/appdata/stock-analyzer  (if your pool is named "cache")
ZFS_APPDATA_PATH=/mnt/cache/appdata/stock-analyzer

# ── Proxmox-specific ───────────────────────────────────────────────────────────
# Path inside the LXC where your fast NVMe dataset is bind-mounted.
PRIMARY_DATA_PATH=/opt/stock-analyzer

# Path inside the LXC where your backup storage is mounted (NFS / secondary disk).
BACKUP_HOST_PATH=/mnt/backups/stock-analyzer
