# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
TRADING212_API_KEY=...          # T212 Settings → API

# ── Web UI authentication (strongly recommended) ───────────────────────────────
# Set both to enable HTTP Basic Auth on every page and API endpoint.
# Without these, anyone on your network can view your portfolio and trigger
# analysis runs (which cost Anthropic API credits).
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme

# ── Optional (defaults shown) ─────────────────────────────────────────────────
EXCEL_PATH=/data/stocks/stocks.xlsx
DB_PATH=/data/db/stocks.db
REPORTS_DIR=/data/reports

# Report encryption — set to any password to enable.
# Excel files will be password-protected; text reports will be Fernet-encrypted.
# Use a different value from DASHBOARD_PASSWORD so a leaked report password
# does not also unlock the web UI.
REPORTS_ENCRYPTION_KEY=

# How many days of reports to keep before auto-deletion
REPORTS_RETENTION_DAYS=365

# Analysis schedule — days are 0=Mon … 6=Sun, comma-separated
SCHEDULE_DAYS=0,2,5             # Mon/Wed/Sat
SCHEDULE_HOUR=7                 # 07:00 UTC

# Trading 212 sync
T212_SYNC_ENABLED=true
T212_SYNC_OFFSET_MINS=30        # sync this many mins before each analysis run
COST_METHOD=AVCO                # FIFO | AVCO

PORT=8765
